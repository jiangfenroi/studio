rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MEDICAL ANOMALY RESULT MANAGEMENT SYSTEM - SECURITY POSTURE
     *
     * Core Philosophy: 
     * This ruleset implements a Database-Backed Access Control (DBAC) model for a clinical environment. 
     * Access to patient data is restricted to users identified as 'Medical Staff'.
     *
     * Data Structure:
     * - /roles_medicalStaff/{userId}: A registry of authorized staff members.
     * - /patientProfiles/{patientProfileId}: Top-level patient demographic data.
     * - /patientProfiles/.../medicalAnomalyRecords/{recordId}: Records of clinical anomalies.
     * - /patientProfiles/.../medicalReportFiles/{fileId}: Metadata for uploaded medical reports.
     *
     * Key Security Decisions:
     * 1. DBAC over Custom Claims: Staff authorization is determined by the existence of a document 
     *    in the `roles_medicalStaff` collection matching the user's UID.
     * 2. Role-Based Shared Access: Any user verified as medical staff has full read/write access 
     *    to all patient-related collections to facilitate collaborative clinical care.
     * 3. Relational Integrity: Rules enforce that internal document fields (like patientProfileId) 
     *    match the hierarchical path to prevent orphaned or misplaced data.
     * 4. Prototyping Flexibility: Data types and specific object shapes are not strictly enforced, 
     *    allowing for rapid iteration of the clinical data model.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user exists in the medical staff registry. */
    function isMedicalStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_medicalStaff/$(request.auth.uid));
    }

    /** @description Combined check for staff status and existence of the document for updates/deletes. */
    function isExistingMedicalStaff() {
      return isMedicalStaff() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Collection for storing user roles. Existence of a UID here grants staff privileges.
     * @path /roles_medicalStaff/{userId}
     * @allow (get) Signed-in users checking their own or others' roles.
     * @deny (write) Any client-side modification; roles should be managed via admin tools.
     * @principle Database-Backed Access Control (DBAC).
     */
    match /roles_medicalStaff/{userId} {
      allow get: if isSignedIn();
      allow list: if isMedicalStaff();
      allow create, update, delete: if false; 
    }

    /**
     * @description Core patient demographic information.
     * @path /patientProfiles/{patientProfileId}
     * @allow (create) Medical staff providing matching archive number (id) in data.
     * @deny (read/write) Any user not present in the roles_medicalStaff collection.
     * @principle Path-based relational integrity and role-based access.
     */
    match /patientProfiles/{patientProfileId} {
      allow get, list: if isMedicalStaff();
      allow create: if isMedicalStaff() && request.resource.data.id == patientProfileId;
      allow update: if isExistingMedicalStaff() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingMedicalStaff();

      /**
       * @description Records of significant abnormal results for a specific patient.
       * @path /patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}
       * @allow (create) Staff linking the record correctly to the parent patientProfileId.
       * @deny (update) Changing the patientProfileId link after creation.
       * @principle Hierarchical data integrity.
       */
      match /medicalAnomalyRecords/{medicalAnomalyRecordId} {
        allow get, list: if isMedicalStaff();
        allow create: if isMedicalStaff() && request.resource.data.patientProfileId == patientProfileId;
        allow update: if isExistingMedicalStaff() && request.resource.data.patientProfileId == resource.data.patientProfileId;
        allow delete: if isExistingMedicalStaff();

        /**
         * @description Metadata and storage links for medical report files (PDFs).
         * @path /patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}/medicalReportFiles/{medicalReportFileId}
         * @allow (create) Staff linking the file record to the parent anomaly record.
         * @deny (list) Users who are not authenticated medical staff.
         * @principle Authorization independence via path hierarchy.
         */
        match /medicalReportFiles/{medicalReportFileId} {
          allow get, list: if isMedicalStaff();
          allow create: if isMedicalStaff() && request.resource.data.medicalAnomalyRecordId == medicalAnomalyRecordId;
          allow update: if isExistingMedicalStaff() && request.resource.data.medicalAnomalyRecordId == resource.data.medicalAnomalyRecordId;
          allow delete: if isExistingMedicalStaff();
        }
      }
    }
  }
}