
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MEDICAL ANOMALY RESULT MANAGEMENT SYSTEM - SECURITY POSTURE
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMedicalStaff() {
      return isSignedIn();
    }

    match /systemConfig/{configId} {
      allow read: if true;
      allow write: if isMedicalStaff();
    }

    match /staffProfiles/{staffId} {
      allow read, write: if isMedicalStaff();
    }

    match /medicalReportFiles/{fileId} {
      allow read, write: if isMedicalStaff();
    }

    match /patientProfiles/{patientProfileId} {
      allow read, write: if isMedicalStaff();

      match /medicalAnomalyRecords/{medicalAnomalyRecordId} {
        allow read, write: if isMedicalStaff();
      }
    }

    match /{path=**}/medicalAnomalyRecords/{medicalAnomalyRecordId} {
      allow list: if isMedicalStaff();
    }
  }
}
