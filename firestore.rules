rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MEDICAL ANOMALY RESULT MANAGEMENT SYSTEM - SECURITY POSTURE
     *
     * Core Philosophy: 
     * This ruleset implements a Database-Backed Access Control (DBAC) model for a clinical environment. 
     * 
     * Prototype Mode:
     * For this prototype, 'isMedicalStaff' is relaxed to any signed-in user.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Relaxed staff check for prototype: any signed-in user is considered staff. */
    function isMedicalStaff() {
      return isSignedIn();
    }

    /** @description Combined check for staff status and existence of the document for updates/deletes. */
    function isExistingMedicalStaff() {
      return isMedicalStaff() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Collection for storing user roles.
     */
    match /roles_medicalStaff/{userId} {
      allow get: if isSignedIn();
      allow list: if isMedicalStaff();
      allow create, update, delete: if false; 
    }

    /**
     * @description Global system settings. Public read allowed for initial app config loading.
     */
    match /systemConfig/{configId} {
      allow get: if true;
      allow list, write: if isMedicalStaff();
    }

    /**
     * @description Flat collection for medical report metadata.
     */
    match /medicalReportFiles/{fileId} {
      allow get, list: if isMedicalStaff();
      allow create: if isMedicalStaff();
      allow update, delete: if isExistingMedicalStaff();
    }

    /**
     * @description Core patient demographic information.
     */
    match /patientProfiles/{patientProfileId} {
      allow get, list: if isMedicalStaff();
      allow create: if isMedicalStaff();
      allow update: if isExistingMedicalStaff();
      allow delete: if isExistingMedicalStaff();

      /**
       * @description Records of significant abnormal results for a specific patient.
       */
      match /medicalAnomalyRecords/{medicalAnomalyRecordId} {
        allow get, list: if isMedicalStaff();
        allow create: if isMedicalStaff();
        allow update: if isExistingMedicalStaff();
        allow delete: if isExistingMedicalStaff();

        /**
         * @description Metadata for medical report files nested within anomaly records.
         */
        match /medicalReportFiles/{medicalReportFileId} {
          allow get, list: if isMedicalStaff();
          allow create, update, delete: if isMedicalStaff();
        }
      }
    }
  }
}