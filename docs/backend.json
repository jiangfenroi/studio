
{
  "entities": {
    "PatientProfile": {
      "title": "PatientProfile",
      "type": "object",
      "description": "Represents the personal information of a patient identified by their unique archive number.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Archive Number)."
        },
        "name": {
          "type": "string"
        },
        "gender": {
          "type": "string",
          "enum": ["男", "女", "其他"]
        },
        "age": {
          "type": "number"
        },
        "idNumber": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["正常", "死亡", "无法联系"],
          "default": "正常"
        }
      },
      "required": ["id", "status"]
    },
    "MedicalAnomalyRecord": {
      "title": "MedicalAnomalyRecord",
      "type": "object",
      "description": "Records clinical events, including initial abnormal findings and subsequent professional follow-ups.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "checkupNumber": {
          "type": "string",
          "description": "12-digit exam number."
        },
        "checkupDate": {
          "type": "string",
          "format": "date"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "anomalyCategory": {
          "type": "string",
          "enum": ["A", "B"],
          "description": "Present for initial findings."
        },
        "anomalyDetails": {
          "type": "string"
        },
        "disposalSuggestions": {
          "type": "string"
        },
        "isNotified": {
          "type": "boolean"
        },
        "notifiedPerson": {
          "type": "string"
        },
        "notifiedPersonFeedback": {
          "type": "string"
        },
        "notifier": {
          "type": "string"
        },
        "notificationDate": {
          "type": "string"
        },
        "notificationTime": {
          "type": "string"
        },
        "associatedAnomalyId": {
          "type": "string",
          "description": "Present for follow-up records, links to the original anomaly."
        },
        "followUpResult": {
          "type": "string"
        },
        "followUpPerson": {
          "type": "string"
        },
        "followUpDate": {
          "type": "string"
        },
        "followUpTime": {
          "type": "string"
        },
        "isReExamined": {
          "type": "boolean"
        },
        "nextFollowUpDate": {
          "type": "string",
          "description": "Manually set date for the next follow-up."
        },
        "isClosed": {
          "type": "boolean",
          "description": "True if the clinical task is finalized."
        }
      }
    },
    "MedicalReportFile": {
      "title": "MedicalReportFile",
      "type": "object",
      "description": "Metadata for uploaded medical reports.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "associatedRecordId": {
          "type": "string"
        },
        "fileName": {
          "type": "string"
        },
        "fullPath": {
          "type": "string"
        },
        "checkDate": {
          "type": "string",
          "format": "date"
        },
        "reportCategory": {
          "type": "string",
          "enum": ["体检报告", "影像检查报告", "病理检查报告", "内镜报告"]
        }
      }
    },
    "StaffProfile": {
      "title": "StaffProfile",
      "type": "object",
      "description": "Metadata for system users.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "jobId": { "type": "string" },
        "role": { "type": "string", "enum": ["管理员", "医生", "护士"] },
        "status": { "type": "string", "enum": ["在职", "离职"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/systemConfig/{configId}": {
      "schema": "#/backend/entities/SystemConfig",
      "description": "Global settings."
    },
    "/staffProfiles/{staffId}": {
      "schema": "#/backend/entities/StaffProfile",
      "description": "User profiles."
    },
    "/patientProfiles/{patientProfileId}": {
      "schema": "#/backend/entities/PatientProfile",
      "description": "Top-level patient documents."
    },
    "/patientProfiles/{patientProfileId}/medicalAnomalyRecords/{recordId}": {
      "schema": "#/backend/entities/MedicalAnomalyRecord",
      "description": "Subcollection for all clinical interactions."
    },
    "/medicalReportFiles/{fileId}": {
      "schema": "#/backend/entities/MedicalReportFile",
      "description": "Flattened report index."
    }
  }
}
