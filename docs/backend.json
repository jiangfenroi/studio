
{
  "entities": {
    "PatientProfile": {
      "title": "PatientProfile",
      "type": "object",
      "description": "Represents the personal information of a patient identified by their unique archive number.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Archive Number)."
        },
        "name": {
          "type": "string"
        },
        "gender": {
          "type": "string",
          "enum": ["男", "女", "其他"]
        },
        "age": {
          "type": "number"
        },
        "idNumber": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["正常", "死亡", "无法联系"],
          "default": "正常"
        },
        "lastExamDate": {
          "type": "string",
          "format": "date"
        }
      },
      "required": ["id", "name", "gender", "age", "phoneNumber", "status"]
    },
    "MedicalAnomalyRecord": {
      "title": "MedicalAnomalyRecord",
      "type": "object",
      "description": "Records details of a significant abnormal result found during a medical checkup.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "checkupNumber": {
          "type": "string"
        },
        "checkupDate": {
          "type": "string",
          "format": "date"
        },
        "notifiedPerson": {
          "type": "string"
        },
        "anomalyCategory": {
          "type": "string",
          "enum": ["A", "B"]
        },
        "anomalyDetails": {
          "type": "string"
        },
        "disposalSuggestions": {
          "type": "string"
        },
        "isNotified": {
          "type": "boolean"
        },
        "isHealthEducationProvided": {
          "type": "boolean"
        },
        "notifier": {
          "type": "string"
        },
        "notifiedPersonFeedback": {
          "type": "string"
        },
        "notificationDate": {
          "type": "string",
          "format": "date"
        },
        "notificationTime": {
          "type": "string",
          "format": "time"
        }
      },
      "required": ["id", "patientProfileId", "checkupNumber", "checkupDate"]
    },
    "MedicalReportFile": {
      "title": "MedicalReportFile",
      "type": "object",
      "description": "Stores metadata and links for uploaded PDF medical reports with hierarchical path logic.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "associatedRecordId": {
          "type": "string",
          "description": "Reference to either a MedicalAnomalyRecord or a FollowUpRecord."
        },
        "fileName": {
          "type": "string"
        },
        "basePath": {
          "type": "string",
          "description": "The root storage path configured in settings."
        },
        "fullPath": {
          "type": "string",
          "description": "Computed path: basePath/archiveNo/reportCategory/fileName"
        },
        "checkDate": {
          "type": "string",
          "format": "date"
        },
        "reportCategory": {
          "type": "string",
          "enum": ["体检报告", "影像报告", "病理报告", "内镜报告"]
        }
      },
      "required": ["id", "patientProfileId", "fileName", "fullPath", "checkDate", "reportCategory"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "type": "object",
      "description": "Global system settings including PDF storage paths.",
      "properties": {
        "id": {
          "type": "string",
          "default": "default"
        },
        "pdfStoragePath": {
          "type": "string",
          "description": "The designated internal network path for PDF storage (e.g., ftp://... or //...)"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/systemConfig/{configId}",
        "definition": {
          "entityName": "SystemConfig",
          "schema": { "$ref": "#/backend/entities/SystemConfig" },
          "description": "Global settings for the application."
        }
      },
      {
        "path": "/patientProfiles/{patientProfileId}",
        "definition": {
          "entityName": "PatientProfile",
          "schema": { "$ref": "#/backend/entities/PatientProfile" },
          "description": "Top-level collection for patient profiles."
        }
      },
      {
        "path": "/patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}",
        "definition": {
          "entityName": "MedicalAnomalyRecord",
          "schema": { "$ref": "#/backend/entities/MedicalAnomalyRecord" },
          "description": "Subcollection for anomaly records."
        }
      },
      {
        "path": "/medicalReportFiles/{fileId}",
        "definition": {
          "entityName": "MedicalReportFile",
          "schema": { "$ref": "#/backend/entities/MedicalReportFile" },
          "description": "Flattened access for reporting and linking files."
        }
      }
    ]
  }
}
