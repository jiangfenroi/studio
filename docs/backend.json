
{
  "entities": {
    "PatientProfile": {
      "title": "PatientProfile",
      "type": "object",
      "description": "Represents the personal information of a patient identified by their unique archive number.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Archive Number)."
        },
        "name": {
          "type": "string"
        },
        "gender": {
          "type": "string",
          "enum": ["男", "女", "其他"]
        },
        "age": {
          "type": "number"
        },
        "idNumber": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["正常", "死亡", "无法联系"],
          "default": "正常"
        },
        "lastExamDate": {
          "type": "string",
          "format": "date"
        }
      },
      "required": ["id", "name", "gender", "age", "phoneNumber", "status"]
    },
    "MedicalAnomalyRecord": {
      "title": "MedicalAnomalyRecord",
      "type": "object",
      "description": "Records details of a significant abnormal result found during a medical checkup.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "checkupNumber": {
          "type": "string"
        },
        "checkupDate": {
          "type": "string",
          "format": "date"
        },
        "notifiedPerson": {
          "type": "string"
        },
        "anomalyCategory": {
          "type": "string",
          "enum": ["A", "B"]
        },
        "anomalyDetails": {
          "type": "string"
        },
        "disposalSuggestions": {
          "type": "string"
        },
        "isNotified": {
          "type": "boolean"
        },
        "isHealthEducationProvided": {
          "type": "boolean"
        },
        "notifier": {
          "type": "string"
        },
        "notifiedPersonFeedback": {
          "type": "string"
        },
        "notificationDate": {
          "type": "string",
          "format": "date"
        },
        "notificationTime": {
          "type": "string",
          "format": "time"
        }
      },
      "required": ["id", "patientProfileId", "checkupNumber", "checkupDate"]
    },
    "MedicalReportFile": {
      "title": "MedicalReportFile",
      "type": "object",
      "description": "Stores metadata and links for uploaded PDF medical reports with hierarchical path logic.",
      "properties": {
        "id": {
          "type": "string"
        },
        "patientProfileId": {
          "type": "string"
        },
        "associatedRecordId": {
          "type": "string",
          "description": "Reference to either a MedicalAnomalyRecord or a FollowUpRecord."
        },
        "fileName": {
          "type": "string"
        },
        "basePath": {
          "type": "string",
          "description": "The root storage path configured in settings."
        },
        "fullPath": {
          "type": "string",
          "description": "Computed path: basePath/archiveNo/reportCategory/fileName"
        },
        "checkDate": {
          "type": "string",
          "format": "date"
        },
        "reportCategory": {
          "type": "string",
          "enum": ["体检报告", "影像报告", "病理报告", "内镜报告"]
        }
      },
      "required": ["id", "patientProfileId", "fileName", "fullPath", "checkDate", "reportCategory"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "type": "object",
      "description": "Global system settings including PDF storage paths and app branding.",
      "properties": {
        "id": {
          "type": "string",
          "default": "default"
        },
        "appName": {
          "type": "string",
          "description": "Customized system name."
        },
        "appLogoFileName": {
          "type": "string",
          "description": "Logo filename stored in the root of the PDF storage path."
        },
        "pdfStoragePath": {
          "type": "string",
          "description": "The designated internal network path for PDF storage."
        },
        "pacsUrlBase": {
          "type": "string",
          "description": "Base URL for PACS integration (e.g., http://172.16.201.61:7242/?ChtId=)."
        },
        "mysql": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "database": { "type": "string" }
          }
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "StaffProfile": {
      "title": "StaffProfile",
      "type": "object",
      "description": "Metadata for system users/clinical staff.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["管理员", "医生", "护士"] },
        "jobId": { "type": "string" },
        "status": { "type": "string", "enum": ["在职", "离职"] }
      },
      "required": ["id", "name", "email", "role"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/systemConfig/{configId}": {
      "schema": "#/backend/entities/SystemConfig",
      "description": "Global settings for the application."
    },
    "/staffProfiles/{staffId}": {
      "schema": "#/backend/entities/StaffProfile",
      "description": "Clinical staff and system user metadata."
    },
    "/patientProfiles/{patientProfileId}": {
      "schema": "#/backend/entities/PatientProfile",
      "description": "Top-level collection for patient profiles."
    },
    "/patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}": {
      "schema": "#/backend/entities/MedicalAnomalyRecord",
      "description": "Subcollection for anomaly records."
    },
    "/medicalReportFiles/{fileId}": {
      "schema": "#/backend/entities/MedicalReportFile",
      "description": "Flattened access for reporting and linking files."
    }
  }
}
