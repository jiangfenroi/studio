
{
  "entities": {
    "PatientProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PatientProfile",
      "type": "object",
      "description": "Represents the personal information of a patient identified by their unique archive number. This entity stores core demographic and contact details.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PatientProfile entity, corresponding to the patient's archive number. (Primary Key)"
        },
        "name": {
          "type": "string",
          "description": "The full name of the patient."
        },
        "gender": {
          "type": "string",
          "enum": ["男", "女", "其他"],
          "description": "The gender of the patient."
        },
        "age": {
          "type": "number",
          "description": "The age of the patient."
        },
        "idNumber": {
          "type": "string",
          "description": "The national ID number of the patient."
        },
        "organization": {
          "type": "string",
          "description": "The patient's workplace or organization."
        },
        "address": {
          "type": "string",
          "description": "The home address of the patient."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The contact phone number of the patient."
        },
        "status": {
          "type": "string",
          "enum": ["正常", "死亡", "无法联系"],
          "default": "正常",
          "description": "The current status of the patient."
        },
        "lastExamDate": {
          "type": "string",
          "format": "date",
          "description": "The date of the last medical checkup."
        }
      },
      "required": [
        "id",
        "name",
        "gender",
        "age",
        "phoneNumber",
        "status"
      ]
    },
    "MedicalAnomalyRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MedicalAnomalyRecord",
      "type": "object",
      "description": "Records details of a significant abnormal result found during a medical checkup, including notification and suggested actions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MedicalAnomalyRecord entity. (Primary Key)"
        },
        "patientProfileId": {
          "type": "string",
          "description": "Reference to the PatientProfile entity's ID (archiveNumber)."
        },
        "checkupNumber": {
          "type": "string",
          "description": "The 12-digit checkup identification number."
        },
        "checkupDate": {
          "type": "string",
          "description": "The date when the medical checkup was performed.",
          "format": "date"
        },
        "notifiedPerson": {
          "type": "string",
          "description": "The name of the person who was notified."
        },
        "anomalyCategory": {
          "type": "string",
          "enum": ["A", "B"],
          "description": "Category A (Immediate) or B (Clinical examination)."
        },
        "anomalyDetails": {
          "type": "string",
          "description": "Detailed description of the anomaly."
        },
        "disposalSuggestions": {
          "type": "string",
          "description": "Recommendations for management."
        },
        "isNotified": {
          "type": "boolean",
          "description": "Has the person been informed."
        },
        "isHealthEducationProvided": {
          "type": "boolean",
          "description": "Was health education provided."
        },
        "notifier": {
          "type": "string",
          "description": "System user who performed notification."
        },
        "notifiedPersonFeedback": {
          "type": "string",
          "description": "Feedback from the patient/family."
        },
        "notificationDate": {
          "type": "string",
          "format": "date"
        },
        "notificationTime": {
          "type": "string",
          "format": "time"
        }
      },
      "required": [
        "id",
        "patientProfileId",
        "checkupNumber",
        "checkupDate",
        "notifiedPerson",
        "anomalyCategory",
        "anomalyDetails",
        "disposalSuggestions",
        "isNotified",
        "isHealthEducationProvided",
        "notifier",
        "notificationDate",
        "notificationTime"
      ]
    },
    "MedicalReportFile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MedicalReportFile",
      "type": "object",
      "description": "Stores metadata and links for uploaded PDF medical reports.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "medicalAnomalyRecordId": {
          "type": "string",
          "description": "Parent anomaly record reference."
        },
        "patientProfileId": {
          "type": "string",
          "description": "Grandparent patient reference."
        },
        "fileName": {
          "type": "string"
        },
        "filePath": {
          "type": "string",
          "format": "uri"
        },
        "checkDate": {
          "type": "string",
          "format": "date"
        },
        "fileCategory": {
          "type": "string",
          "enum": ["体检报告", "影像检查报告", "病理检查报告"]
        }
      },
      "required": [
        "id",
        "medicalAnomalyRecordId",
        "patientProfileId",
        "fileName",
        "filePath",
        "checkDate",
        "fileCategory"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/roles_medicalStaff/{userId}",
        "definition": {
          "entityName": "user",
          "schema": {
            "$ref": "#/backend/entities/user"
          },
          "description": "Collection for storing user roles."
        }
      },
      {
        "path": "/patientProfiles/{patientProfileId}",
        "definition": {
          "entityName": "PatientProfile",
          "schema": {
            "$ref": "#/backend/entities/PatientProfile"
          },
          "description": "Top-level collection for patient profiles."
        }
      },
      {
        "path": "/patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}",
        "definition": {
          "entityName": "MedicalAnomalyRecord",
          "schema": {
            "$ref": "#/backend/entities/MedicalAnomalyRecord"
          },
          "description": "Subcollection for anomaly records."
        }
      },
      {
        "path": "/patientProfiles/{patientProfileId}/medicalAnomalyRecords/{medicalAnomalyRecordId}/medicalReportFiles/{medicalReportFileId}",
        "definition": {
          "entityName": "MedicalReportFile",
          "schema": {
            "$ref": "#/backend/entities/MedicalReportFile"
          },
          "description": "Subcollection for report files."
        }
      }
    ]
  }
}
